# local | production
ENVIRONMENT=local

# Postgres connection (Supabase provides these under Project Settings -> Database)
POSTGRES_SERVER=db.your-supabase-project-id.supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_KEY = ${SUPABASE_SERVICE_ROLE_KEY}

# Google Geocoding API key used to generate lat/long for events
base_geo=